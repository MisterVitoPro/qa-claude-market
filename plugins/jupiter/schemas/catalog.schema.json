{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Jupiter Catalog",
  "type": "object",
  "required": ["mode", "specs", "proposed_layout", "cross_refs"],
  "additionalProperties": false,
  "properties": {
    "mode": { "enum": ["module", "feature"] },
    "specs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "loc",
          "mtime",
          "topics",
          "bucket",
          "headings",
          "cross_refs"
        ],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "loc": { "type": "integer", "minimum": 0 },
          "mtime": { "type": "string", "format": "date-time" },
          "topics": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 3,
            "maxItems": 7
          },
          "bucket": { "type": "string" },
          "headings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["heading", "line", "loc"],
              "additionalProperties": false,
              "properties": {
                "heading": { "type": "string" },
                "line": { "type": "integer", "minimum": 1 },
                "loc": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "cross_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "proposed_layout": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "cross_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" }
        }
      }
    }
  }
}
